# ==============================================================================
# SCABD & JULES INTEGRATION BOUNDARIES
# ==============================================================================
ENVIRONMENT=development
LOG_LEVEL=info
SCABD_PATH="./scabd"
LOG_DIR="./scabd/logs"
SCABD_API_PORT=8080
JULES_BRIDGE_TIMEOUT=30
DATA_HEALING_MODE=true
ENFORCE_GPL_COMPLIANCE=true
SYSTEM_ENCRYPTION_KEY=your_fernet_or_aes_key_here
